<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCDCDC">

    <ImageView
        android:id="@+id/iv_stylus_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/playing_stylus_lp_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.yibao.music.activity.view.RotatableNeedleView
        android:id="@+id/stylusContainer"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_gravity="end"
        android:background="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_stylus_bg">

        <ImageView
            android:id="@+id/iv_stylus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:src="@drawable/playing_stylus_lp" />
    </com.yibao.music.activity.view.RotatableNeedleView>

    <ImageView
        android:id="@+id/iv_stylus_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/playing_stylus_lp_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
